{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Escalation Criteria — AI + 人間 1 名運用の判定基準",
  "description": "Green/Yellow/Red の機械判定基準。人間の出番を最小化し、Red のみ人間承認を必須とする。",
  "version": "1.0.0",
  "updatedAt": "2026-04-05",

  "levels": {
    "green": {
      "label": "Green — AI 自動進行",
      "conditions": [
        "Hard Gate PASS",
        "WARN KPIs = 0",
        "guard tests 全 pass",
        "docs:check PASS"
      ],
      "aiAction": "自動進行。通知不要。",
      "humanAction": "不要"
    },
    "yellow": {
      "label": "Yellow — AI 進行 + 要約通知",
      "conditions": [
        "Hard Gate PASS",
        "WARN KPIs >= 1"
      ],
      "aiAction": "進行する。WARN 内容を要約して人間に通知。",
      "humanAction": "通知確認のみ"
    },
    "red": {
      "label": "Red — AI 停止、人間承認待ち",
      "conditions": [
        "Hard Gate FAIL",
        "以下の Red 条件のいずれかに該当"
      ],
      "aiAction": "停止。人間に承認を求める。",
      "humanAction": "判断・承認"
    }
  },

  "redConditions": [
    {
      "id": "RED-01",
      "trigger": "docs.obligation.violations > 0",
      "reason": "Hard Gate FAIL"
    },
    {
      "id": "RED-02",
      "trigger": "references/01-principles/ 配下の変更",
      "reason": "設計原則の変更は不可逆性が高い"
    },
    {
      "id": "RED-03",
      "trigger": "新規 frozen / allowlist / bridge 追加",
      "reason": "no-new-debt ルール違反の可能性"
    },
    {
      "id": "RED-04",
      "trigger": "authoritative 昇格",
      "reason": "promotion-criteria.md に明記済み"
    },
    {
      "id": "RED-05",
      "trigger": "Hard Gate fail override",
      "reason": "安全基準の一時的緩和"
    },
    {
      "id": "RED-06",
      "trigger": "不可逆移行（ファイル削除、型の breaking change）",
      "reason": "rollback 不可の変更"
    }
  ],

  "noNewDebt": {
    "description": "以下は新規追加禁止。noNewDebtGuard.test.ts で機械的に検証。",
    "prohibitions": [
      "dual-run compare コード（getExecutionMode / recordCall）",
      "dualRunObserver.ts の復活",
      "ExecutionMode への dual-run-compare 再導入",
      "presentation 層からの wasmEngine 直接 import"
    ]
  },

  "relatedDocs": [
    "references/03-guides/safety-first-architecture-plan.md",
    "references/02-status/promotion-criteria.md",
    "app/src/test/guards/noNewDebtGuard.test.ts"
  ]
}
