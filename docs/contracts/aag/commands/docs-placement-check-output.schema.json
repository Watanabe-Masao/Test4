{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aag.local/schemas/docs-placement-check-v1.json",
  "title": "Docs Placement Check Output v1",
  "description": "aag docs placement-check の output envelope。schema / generated artifact の配置規約違反を articulate するための substrate。",
  "$comment": "v4.2 stable-schemas-phase2 で institute。canonical Go implementation: aag-engine/internal/cleanliness/docs_placement.go。",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "violations", "stats", "conventions", "summary"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "docs-placement-check-v1" },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["path", "kind", "reason", "severity"],
        "properties": {
          "path": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["schema-misplaced", "generated-misplaced"]
          },
          "reason": { "type": "string" },
          "severity": { "type": "string", "enum": ["warn", "error"] },
          "action": { "type": "string" }
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": { "type": "integer" }
    },
    "conventions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["kind", "description", "path"],
        "properties": {
          "kind": { "type": "string" },
          "description": { "type": "string" },
          "path": { "type": "string", "description": "正しい配置 path articulate" }
        }
      },
      "description": "articulate される正しい配置 convention 一覧"
    },
    "summary": { "type": "string" }
  }
}
