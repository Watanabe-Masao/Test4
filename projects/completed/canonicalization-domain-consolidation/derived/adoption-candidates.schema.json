{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adoption-candidates.schema.json",
  "title": "canonicalization-domain-consolidation Adoption Candidates",
  "description": "Phase A 採用候補リストの machine-readable 構造化版 schema。prose 正本は references/03-guides/integrity-pair-inventory.md §4。",
  "type": "object",
  "required": [
    "version",
    "generated",
    "source",
    "selectionRule",
    "existingPairs",
    "horizontalCandidates",
    "deferred",
    "rejected",
    "primitives"
  ],
  "additionalProperties": true,
  "properties": {
    "$comment": { "type": "string" },
    "$schema": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "semver"
    },
    "generated": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date (YYYY-MM-DD)"
    },
    "source": {
      "type": "string",
      "description": "prose 正本の参照 (references/03-guides/integrity-pair-inventory.md §N)"
    },
    "selectionRule": {
      "type": "object",
      "required": ["source", "gates", "tieBreakers"],
      "properties": {
        "source": { "type": "string" },
        "gates": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/SelectionCriterion" }
        },
        "tieBreakers": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/SelectionCriterion" }
        }
      }
    },
    "existingPairs": {
      "type": "array",
      "minItems": 13,
      "maxItems": 13,
      "items": { "$ref": "#/$defs/ExistingPair" }
    },
    "horizontalCandidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/HorizontalCandidate" }
    },
    "deferred": {
      "type": "array",
      "items": { "$ref": "#/$defs/DeferredCandidate" }
    },
    "rejected": {
      "type": "array",
      "description": "Phase A inventory のスロット名で起案されたが、実装段階で「採用しない」と決定された slot 群。AR-INTEGRITY-NO-RESURRECT (将来 guard) で同名 primitive の resurrection を機械検出する archive。`deferred` (後続 project に handoff) とは別概念。",
      "items": { "$ref": "#/$defs/RejectedSlot" }
    },
    "phaseHEntryRequirement": {
      "type": "string",
      "description": "Phase H 着手 PR で tier1 候補に対して selection rule (G-1/G-2/G-3) を再判定する義務 (Phase A〜H 間隔による前提 drift を吸収)。"
    },
    "primitives": {
      "type": "object",
      "required": ["parsing", "detection", "reporting", "types"],
      "properties": {
        "$comment": { "type": "string" },
        "parsing": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": {
            "type": "string",
            "enum": [
              "jsonRegistry",
              "tsRegistry",
              "yamlFrontmatter",
              "filesystemRegistry",
              "markdownIdScan",
              "jsdocTag"
            ]
          }
        },
        "detection": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": [
              "existence",
              "pathExistence",
              "shapeSync",
              "ratchet",
              "temporal",
              "setRelation",
              "bidirectionalReference",
              "cardinality"
            ]
          }
        },
        "reporting": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "types": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "SelectionCriterion": {
      "type": "object",
      "required": ["id", "name", "criterion"],
      "properties": {
        "id": { "type": "string", "pattern": "^[GC]-\\d+$" },
        "name": { "type": "string" },
        "criterion": { "type": "string" }
      }
    },
    "Risk": {
      "type": "string",
      "enum": ["lowest", "low", "medium", "medium-high", "high"]
    },
    "Phase": {
      "type": "string",
      "enum": ["B", "C", "D-W1", "D-W2", "D-W3", "E", "H"]
    },
    "Tier": {
      "type": "string",
      "enum": ["tier1", "tier2", "rejected"]
    },
    "PrimitiveName": {
      "type": "string",
      "enum": [
        "jsonRegistry",
        "tsRegistry",
        "yamlFrontmatter",
        "filesystemRegistry",
        "markdownIdScan",
        "jsdocTag",
        "existence",
        "pathExistence",
        "shapeSync",
        "ratchet",
        "temporal",
        "setRelation",
        "bidirectionalReference",
        "cardinality",
        "tokenInclusion",
        "formatViolation"
      ]
    },
    "ExistingPair": {
      "type": "object",
      "required": [
        "priority",
        "pairId",
        "name",
        "registry",
        "guard",
        "risk",
        "phase",
        "primitives"
      ],
      "properties": {
        "priority": { "type": "integer", "minimum": 1, "maximum": 13 },
        "pairId": { "type": "integer", "minimum": 1, "maximum": 13 },
        "name": { "type": "string" },
        "registry": { "type": "string" },
        "guard": { "type": "string" },
        "risk": { "$ref": "#/$defs/Risk" },
        "phase": { "$ref": "#/$defs/Phase" },
        "primitives": {
          "type": "array",
          "items": { "$ref": "#/$defs/PrimitiveName" },
          "minItems": 1
        },
        "note": { "type": "string" }
      }
    },
    "HorizontalCandidate": {
      "type": "object",
      "required": ["priority", "tier", "id", "name", "risk", "primitives"],
      "properties": {
        "priority": {
          "type": "string",
          "pattern": "^H-[αβγδεζη]$"
        },
        "tier": { "$ref": "#/$defs/Tier" },
        "id": { "type": "string", "pattern": "^H-\\d+$" },
        "name": { "type": "string" },
        "risk": { "$ref": "#/$defs/Risk" },
        "primitives": {
          "type": "array",
          "items": { "$ref": "#/$defs/PrimitiveName" }
        },
        "note": { "type": "string" }
      }
    },
    "DeferredCandidate": {
      "type": "object",
      "required": ["id", "name", "tier"],
      "properties": {
        "id": { "type": "string", "pattern": "^H-\\d+$" },
        "name": { "type": "string" },
        "tier": { "$ref": "#/$defs/Tier" },
        "handoffTo": { "type": "string" },
        "rationale": { "type": "string" }
      }
    },
    "RejectedSlot": {
      "type": "object",
      "required": ["originalSlot", "reason", "decidedAt"],
      "properties": {
        "originalSlot": {
          "type": "string",
          "description": "Phase A inventory で起案された primitive 名 (実装には存在しない)"
        },
        "replacedBy": {
          "type": "string",
          "description": "「実装名 (path)」または 「実装せず (理由)」"
        },
        "reason": { "type": "string" },
        "decidedAt": {
          "type": "string",
          "format": "date"
        }
      }
    }
  }
}
