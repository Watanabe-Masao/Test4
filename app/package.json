    "@floating-ui/react-dom": "^2.1.8",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@tanstack/react-table": "^8.21.3",
    "budget-analysis-wasm": "file:../wasm/budget-analysis/pkg",
    "d3-format": "^3.1.2",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "factor-decomposition-wasm": "file:../wasm/factor-decomposition/pkg",
    "forecast-wasm": "file:../wasm/forecast/pkg",
    "framer-motion": "^12.38.0",
    "gross-profit-wasm": "file:../wasm/gross-profit/pkg",
    "observation-period-wasm": "file:../wasm/observation-period/pkg",
    "customer-gap-wasm": "file:../wasm/customer-gap/pkg",
    "pi-value-wasm": "file:../wasm/pi-value/pkg",
    "pin-intervals-wasm": "file:../wasm/pin-intervals/pkg",
    "remaining-budget-rate-wasm": "file:../wasm/remaining-budget-rate/pkg",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "styled-components": "^6.3.9",
    "time-slot-wasm": "file:../wasm/time-slot/pkg",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@storybook/react": "^10.2.10",
    "@storybook/react-vite": "^10.2.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-format": "^3.0.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "storybook": "^10.2.10",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  }
