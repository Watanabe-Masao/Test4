{
  "name": "shiire-arari",
  "private": true,
  "version": "1.8.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build:wasm": "cd ../wasm/factor-decomposition && wasm-pack build --target web --release --out-dir pkg && cd ../gross-profit && wasm-pack build --target web --release --out-dir pkg && cd ../budget-analysis && wasm-pack build --target web --release --out-dir pkg && cd ../forecast && wasm-pack build --target web --release --out-dir pkg && cd ../time-slot && wasm-pack build --target web --release --out-dir pkg && cd ../statistics && wasm-pack build --target web --release --out-dir pkg && cd ../core-utils && wasm-pack build --target web --release --out-dir pkg && cd ../pi-value && wasm-pack build --target web --release --out-dir pkg && cd ../customer-gap && wasm-pack build --target web --release --out-dir pkg && cd ../remaining-budget-rate && wasm-pack build --target web --release --out-dir pkg && cd ../observation-period && wasm-pack build --target web --release --out-dir pkg && cd ../pin-intervals && wasm-pack build --target web --release --out-dir pkg",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:guards": "vitest run src/test/guards/ src/test/comparisonMigrationGuard.test.ts src/test/designSystemGuard.test.ts src/test/documentConsistency.test.ts src/test/scopeBoundaryInvariant.test.ts src/test/scopeConsistencyGuard.test.ts src/test/waterfallDataIntegrity.test.ts",
    "test:observation": "vitest run src/test/observation/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \".storybook/**/*.{ts,tsx}\" \"*.{ts,js,json}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \".storybook/**/*.{ts,tsx}\" \"*.{ts,js,json}\" --ignore-path .prettierignore",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "playwright test visual-regression",
    "health": "npx tsx ../tools/architecture-health/src/main.ts",
    "health:check": "npx tsx ../tools/architecture-health/src/main.ts --check",
    "health:pr-comment": "npx tsx ../tools/architecture-health/src/main.ts --pr-comment",
    "docs:generate": "npx tsx ../tools/architecture-health/src/main.ts",
    "docs:check": "npx tsx ../tools/architecture-health/src/docs-check.ts"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev18.0",
