{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,
    "resolveJsonModule": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases
     *
     * NOTE: `@project-overlay/*` のターゲットは CURRENT_PROJECT.md + project.json
     * 経由で vite / vitest 側では動的解決される（app/scripts/resolve-project-overlay.mjs）。
     * tsconfig は静的 JSON のため、active project を切り替えた場合はこの行と
     * include エントリを手動で更新する必要がある。
     *
     * `@app-domain/*` は repo 直下 app-domain/ を指す（アプリ固有の意味空間）。
     * BaseRule 正本は app-domain/gross-profit/rule-catalog/base-rules.ts に物理配置。
     * 参照: references/03-implementation/governance-final-placement-plan.md
     */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@project-overlay/*": ["../projects/active/pure-calculation-reorg/aag/*"],
      "@app-domain/*": ["../app-domain/*"],
      "@tools/architecture-health/*": ["../tools/architecture-health/src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "src",
    "../projects/active/pure-calculation-reorg/aag/**/*.ts",
    "../app-domain/gross-profit/rule-catalog/**/*.ts",
    "../tools/architecture-health/src/**/*.ts"
  ]
}
