#!/bin/sh
# pre-commit hook — obligation map の局所チェック + 自動再生成
#
# guard / allowlist / health ツールの変更がステージングされている場合、
# architecture-health.json も同時にステージングされていなければ
# docs:generate を自動実行してステージングに追加する。
#
# 「気をつける」で終わらせない。「通らない」にする。（G8）
# 「ブロックするだけでなく解決する」（Adaptive Governance）
#
# CI の docs:check が最終ゲート。このフックは摩擦を最小化する。
#
# セットアップ:
#   cp tools/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

HEALTH_JSON="references/02-status/generated/architecture-health.json"

# ステージング済みファイル一覧
STAGED=$(git diff --cached --name-only 2>/dev/null)

if [ -z "$STAGED" ]; then
  exit 0
fi

# health regeneration が必要なパスパターン（obligation-collector.ts と同期）
NEED_HEALTH_REGEN=0

for pattern in \
  "app/src/test/allowlists/" \
  "app/src/test/guards/" \
  "tools/architecture-health/" \
  "tools/architecture-health/src/config/" \
  "references/02-status/generated/"; do
  if echo "$STAGED" | grep -q "^${pattern}"; then
    NEED_HEALTH_REGEN=1
    break
  fi
done

if [ "$NEED_HEALTH_REGEN" = "0" ]; then
  exit 0
fi

# architecture-health.json がステージングされていれば OK
if echo "$STAGED" | grep -q "^${HEALTH_JSON}"; then
  exit 0
fi

# 自動再生成を試行
echo ""
echo "⚡ Obligation detected — running docs:generate automatically..."
echo ""

if (cd app && npm run docs:generate --silent 2>/dev/null); then
  # 生成されたファイルをステージングに追加
  git add \
    "${HEALTH_JSON}" \
    "references/02-status/generated/architecture-health.md" \
    "references/02-status/generated/architecture-health-certificate.md" \
    "CLAUDE.md" \
    "references/02-status/technical-debt-roadmap.md" \
    2>/dev/null

  echo "  ✓ docs:generate 完了。生成ファイルをステージングに追加しました。"
  echo ""
  exit 0
else
  echo ""
  echo "  ✗ docs:generate に失敗しました。手動で実行してください:"
  echo "    cd app && npm run docs:generate"
  echo ""
  exit 1
fi
