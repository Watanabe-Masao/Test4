#!/bin/sh
# pre-commit hook — obligation map の局所チェック
#
# guard / allowlist / health ツールの変更がステージングされている場合、
# architecture-health.json も同時にステージングされていなければ警告する。
# 「気をつける」で終わらせない。「通らない」にする。（G8）
#
# CI の docs:check が最終ゲートだが、push 前に検出することで手戻りを防ぐ。
#
# セットアップ:
#   cp tools/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

HEALTH_JSON="references/02-status/generated/architecture-health.json"

# ステージング済みファイル一覧
STAGED=$(git diff --cached --name-only 2>/dev/null)

if [ -z "$STAGED" ]; then
  exit 0
fi

# health regeneration が必要なパスパターン（obligation-collector.ts と同期）
NEED_HEALTH_REGEN=0
TRIGGERED_PATHS=""

for pattern in \
  "app/src/test/allowlists/" \
  "app/src/test/guards/" \
  "tools/architecture-health/" \
  "tools/architecture-health/src/config/" \
  "references/02-status/generated/"; do
  if echo "$STAGED" | grep -q "^${pattern}"; then
    NEED_HEALTH_REGEN=1
    TRIGGERED_PATHS="${TRIGGERED_PATHS}\n  - ${pattern}*"
  fi
done

if [ "$NEED_HEALTH_REGEN" = "0" ]; then
  exit 0
fi

# architecture-health.json がステージングされているか
if echo "$STAGED" | grep -q "^${HEALTH_JSON}"; then
  exit 0
fi

echo ""
echo "⚠ Obligation violation detected — health regeneration required"
echo ""
echo "  以下のパスが変更されています:"
echo "$TRIGGERED_PATHS" | sed '/^$/d'
echo ""
echo "  しかし ${HEALTH_JSON} がステージングされていません。"
echo ""
echo "  修正方法:"
echo "    cd app && npm run docs:generate"
echo "    git add ${HEALTH_JSON} CLAUDE.md references/02-status/generated/ references/02-status/technical-debt-roadmap.md"
echo ""
echo "  スキップ（CI で検証する場合）:"
echo "    git commit --no-verify"
echo ""
exit 1
