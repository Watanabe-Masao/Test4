#!/bin/sh
# pre-push hook — CI 前の修正漏れ検出 (violation registry 方式)
#
# ──────────────────────────────────────────────────────────────────────
# 役割 — CI と AAG の分担
# ──────────────────────────────────────────────────────────────────────
#
#   CI  = 正式な完全版チェック (全ファイル / 全ルール / 最終ゲート)
#   AAG = **過去にやらかしたパターンの蓄積知識** を staged scope で即時検出
#
# pre-push は後者の一部を担う。commit を重ねた後の push 直前に「CI で落ちる
# ことが予測できる違反」を検出し、AAG Response で修正手順を返す。目的は
# 「CI を回さなくても、どこをどう直せばいいかのレスポンスを返して、
# 実装者が迷わず修正できる」状態を作ること。
#
# severity は役割ごとに違う:
#
#   - lint / test:guards 失敗              → ERROR  (push を止める)
#   - format:check 違反                    → WARN   (止めない。一括整形推奨)
#   - doc 更新義務違反 (必須の依存更新)    → ERROR
#   - doc 更新義務違反 (非必須の依存更新)  → WARN
#
# format を止めない理由: 複数コミットぶんの軽微な整形違反を一括で
# `npm run format` 修正できるようにする。即時ブロックは pre-commit 側の
# 役割。push 時点では「一括整形して follow-up commit すれば済む」運用に揃える。
# format の最終ゲートは CI fast-gate が担う。
#
# pre-commit vs pre-push の分担:
#   - pre-commit: 高速な check のみ (1 秒以内)。commit を止めることでその場で修正
#   - pre-push:   重い check (lint / test:guards / 全ファイル format:check)
#                 format は止めず warn のみ (一括修正のため)
#
# 対称性検証: CI と pre-commit+pre-push の必須ステップ対称性は
# buildParityAudit.test.ts で機械検証される。
#
# ──────────────────────────────────────────────────────────────────────
# HOW TO ADD A NEW CHECK (学習プロセス)
# ──────────────────────────────────────────────────────────────────────
#
# CI で新しい失敗パターンを踏むたびに、以下 3 ステップで check を追加する:
#
#   1. `check_<name>()` 関数を書く (テンプレートは下記)
#   2. `CHECK_REGISTRY` 変数に関数名を追加
#   3. 関数内で違反があれば `add_error` / `add_warn` を呼ぶ
#
# テンプレート:
#
#   # Check: <短い説明>
#   # 学習ソース: <どの CI 失敗から追加したか / YYYY-MM-DD>
#   # 理由: <なぜこの check が必要か>
#   # severity: error|warn
#   check_<snake_case>() {
#     echo "  pre-push: <短い説明> 実行中..."
#     # 違反検出ロジック
#     if [ "<condition>" = "violated" ]; then
#       add_error "短いメッセージ" \
#         "  修正方法:" \
#         "    cd app && npm run <fix-command>" \
#         "  詳細: <参照ドキュメント>"
#     fi
#   }
#
# add_error / add_warn の引数はすべて 1 行ずつ出力される。
# 修正手順を複数行に分けて書きやすくするための設計。
#
# ──────────────────────────────────────────────────────────────────────
# セットアップ
# ──────────────────────────────────────────────────────────────────────
#   cp tools/git-hooks/pre-push .git/hooks/pre-push
#   chmod +x .git/hooks/pre-push

set -e

# ──────────────────────────────────────────────────────────────────────
# コミット範囲 / 変更ファイル
# ──────────────────────────────────────────────────────────────────────

# pre-push は stdin から <local ref> <local sha> <remote ref> <remote sha> を受け取る
PUSH_RANGE=""
while read -r _ LOCAL_SHA _ REMOTE_SHA; do
  if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
    # 新規ブランチ: main との差分
    PUSH_RANGE="origin/main...$LOCAL_SHA"
  else
    PUSH_RANGE="${REMOTE_SHA}..${LOCAL_SHA}"
  fi
done

if [ -z "$PUSH_RANGE" ]; then
  exit 0
fi

CHANGED_FILES=$(git diff --name-only "$PUSH_RANGE" 2>/dev/null || git diff --name-only HEAD~1 2>/dev/null || echo "")

# 追加されたファイルのみ (--diff-filter=A)。
# 「新規 .md → doc-registry.json 必須」系のチェックに使う。
# 既存ファイルの modification は doc-registry 更新義務がない。
ADDED_FILES=$(git diff --name-only --diff-filter=A "$PUSH_RANGE" 2>/dev/null || echo "")

if [ -z "$CHANGED_FILES" ]; then
  exit 0
fi

# ──────────────────────────────────────────────────────────────────────
# Skip-rules evaluation (= DA-β-001 / negative articulation)
# ──────────────────────────────────────────────────────────────────────
#
# 設計: pre-push hook = 軽量 / 変更箇所 + 影響範囲 / **何を check しないか** で articulate。
# 全スキャンは CI が AI 不可侵の最終ゲートとして担い、pre-push は影響範囲フォーカス
# の即時 feedback layer に純化する。
#
# manifest: tools/git-hooks/pre-push-skip-rules.json (skip-rules-v1)
# evaluator: tools/git-hooks/skip-rules-evaluator.mjs (= matchAll 評価 + skip set 出力)
# baseline: skipRules.length <= skipBaseline (= prePushSkipRulesGuard.test.ts で機械検証)
#
# 詳細: projects/aag-self-hosting-completion/decision-audit.md DA-β-001

SKIP_LIST=""
SKIP_MATCHED_RULES=""

if [ -f tools/git-hooks/pre-push-skip-rules.json ] && [ -f tools/git-hooks/skip-rules-evaluator.mjs ]; then
  EVAL_OUTPUT=$(echo "$CHANGED_FILES" | node tools/git-hooks/skip-rules-evaluator.mjs 2>/dev/null || true)
  if [ -n "$EVAL_OUTPUT" ]; then
    SKIP_MATCHED_RULES=$(echo "$EVAL_OUTPUT" | head -1 | sed 's/^MATCHED://')
    SKIP_LIST=$(echo "$EVAL_OUTPUT" | tail -n +2)
  fi
fi

if [ -n "$SKIP_MATCHED_RULES" ]; then
  echo "  pre-push: skip rules matched [$SKIP_MATCHED_RULES]"
  if [ -n "$SKIP_LIST" ]; then
    SKIP_DISPLAY=$(echo "$SKIP_LIST" | tr '\n' ' ')
    echo "  pre-push: skipping checks: $SKIP_DISPLAY"
  fi
fi

# should_skip <check_name>
# skip evaluation 結果に基づいて check を skip するか判定する
should_skip() {
  [ -z "$SKIP_LIST" ] && return 1
  echo "$SKIP_LIST" | grep -qx "$1"
}

# ──────────────────────────────────────────────────────────────────────
# Violation registry 層
# ──────────────────────────────────────────────────────────────────────

ERRORS=""
WARNINGS=""

# add_error <line> [<line> ...]
# ERROR レベルで違反を記録する (push を止める)
add_error() {
  for line in "$@"; do
    ERRORS="${ERRORS}${line}\n"
  done
}

# add_warn <line> [<line> ...]
# WARN レベルで違反を記録する (push は続行)
add_warn() {
  for line in "$@"; do
    WARNINGS="${WARNINGS}${line}\n"
  done
}

# changed_matches <regex>
# 変更ファイルのうち regex にマッチするものがあれば 0 を返す
changed_matches() {
  echo "$CHANGED_FILES" | grep -qE "$1"
}

# added_matches <regex>
# 新規追加ファイルのうち regex にマッチするものがあれば 0 を返す。
# 既存ファイル modification は含めない。
added_matches() {
  [ -z "$ADDED_FILES" ] && return 1
  echo "$ADDED_FILES" | grep -qE "$1"
}

# ──────────────────────────────────────────────────────────────────────
# Check 関数群
# ──────────────────────────────────────────────────────────────────────
#
# 各 check は CHECK_REGISTRY に登録された順に実行される。
# 追加方法は先頭コメントの HOW TO ADD A NEW CHECK を参照。

# Check: references/ 新規 .md 追加 → doc-registry.json 未更新
# 学習ソース: references/ に文書追加時、doc-registry.json 登録漏れが頻発
# 理由: doc-registry.json は文書レジストリの唯一正本。新規登録漏れは審査不能な
#       文書が repo に混入する原因になる。既存 .md の modification は対象外
#       (登録済みの更新は doc-registry 更新義務がない)
# severity: error (registry) / warn (README)
check_doc_registry() {
  # --diff-filter=A で新規追加のみを対象にする (modification は除外)
  NEW_REFS=$(echo "$ADDED_FILES" \
    | grep "^references/.*\.md$" \
    | grep -v "^references/02-status/generated/" \
    | grep -v "^references/99-archive/" || true)
  [ -z "$NEW_REFS" ] && return 0

  if ! changed_matches "^docs/contracts/doc-registry\.json"; then
    add_error \
      "references/ に新規 .md 追加あり → docs/contracts/doc-registry.json が未更新" \
      "  新規ファイル:"
    OLD_IFS="$IFS"
    IFS='
'
    for f in $NEW_REFS; do
      add_error "    $f"
    done
    IFS="$OLD_IFS"
    add_error \
      "  修正方法:" \
      "    docs/contracts/doc-registry.json の該当カテゴリに新規エントリを追加" \
      "    詳細: references/03-guides/project-checklist-governance.md §8"
  fi
  if ! changed_matches "^references/README\.md"; then
    add_warn "references/ に新規 .md 追加あり → references/README.md の索引更新を推奨"
  fi
}

# Check: references/01-principles/ 変更 → principles.json 未更新
# 学習ソース: 原則文書変更時、principles.json の連鎖更新漏れ
# 理由: principles.json は設計原則体系の唯一正本。ここと references/01-principles/
#       の不一致は documentConsistency.test.ts で落ちる
# 改修 (Phase K Option 1 後続 F、2026-04-29): generated section (docs:generate が
# 自動更新する timestamp 等) のみの変更は false-positive として除外する。手書き
# 部分が変わったときだけ warn する (HANDOFF.md §3.10 で記録された false-positive
# の構造的解消)
# severity: warn
check_principles_json() {
  changed_matches "^references/01-principles/" || return 0
  changed_matches "^docs/contracts/principles\.json" && return 0

  # 各 principle file について、generated section 以外で変更があるかを検査。
  # 全 file が generated-only 変更なら warn を出さない。
  CHANGED_PRINCIPLES=$(echo "$CHANGED_FILES" | grep "^references/01-principles/.*\.md$" || true)
  [ -z "$CHANGED_PRINCIPLES" ] && return 0

  HAS_SUBSTANTIVE=0
  OLD_IFS="$IFS"
  IFS='
'
  # 注意: 本 hook は `set -e` 下で動作するため、helper の exit 1/2 で hook 全体が
  # abort してしまわないよう if/else パターンで分岐する (case $? は set -e 下では
  # 非 0 exit で到達できない)。helper の exit code は:
  #   0 = generated-only (skip / warn 出さない)
  #   1 = substantive change (warn 必須)
  #   2 = 新規ファイル等の error (安全側で substantive 扱い)
  # 1 / 2 のいずれも HAS_SUBSTANTIVE=1 にしたいので else 分岐で一括処理する。
  for f in $CHANGED_PRINCIPLES; do
    if node tools/check-substantive-change.mjs "$f" "$PUSH_RANGE" 2>/dev/null; then
      : # exit 0 = generated-only — skip
    else
      HAS_SUBSTANTIVE=1
      break
    fi
  done
  IFS="$OLD_IFS"

  [ "$HAS_SUBSTANTIVE" = "0" ] && return 0
  add_warn "references/01-principles/ 変更あり → docs/contracts/principles.json が未更新の可能性"
}

# Check: wasm/ 変更 → project-metadata.json 未更新
# 学習ソース: WASM モジュール追加時、project-metadata.json の wasmModules 未更新
# 理由: project-metadata.json は WASM 一覧の唯一正本
# severity: warn
check_project_metadata() {
  changed_matches "^wasm/" || return 0
  changed_matches "^docs/contracts/project-metadata\.json" && return 0
  add_warn "wasm/ 変更あり → docs/contracts/project-metadata.json が未更新の可能性"
}

# Check: guard/allowlist/registry 変更 → docs:generate 未実行
# 学習ソース: guard 追加・allowlist 更新時、architecture-health の再生成漏れ
# 理由: health KPI / project-health は guard/allowlist を元に算出される。
#       再生成しないと generated section が stale になる。
#       check_docs_drift より高速だが path heuristic ベースで漏れがある。
#       comprehensive 検証は check_docs_drift が担う。
# severity: warn
check_docs_generate() {
  GUARD_CHANGED=0
  for pattern in \
    "^app/src/test/allowlists/" \
    "^app/src/test/guards/" \
    "^app/src/test/architectureRules\.ts" \
    "^app/src/test/calculationCanonRegistry\.ts"; do
    if changed_matches "$pattern"; then
      GUARD_CHANGED=1
      break
    fi
  done
  [ "$GUARD_CHANGED" = "0" ] && return 0
  changed_matches "^references/02-status/generated/" && return 0
  add_warn \
    "guard/allowlist/registry 変更あり → docs:generate 未実行の可能性" \
    "  修正方法: cd app && npm run docs:generate"
}

# Check: docs:check (KPI drift / generated section drift / hard gate)
# 学習ソース:
#   - 2026-04-26 CI で docs:check 失敗:
#       KPI drift: project.checklist.checkedCheckboxes — committed: 643, live: 644
#     HANDOFF.md / checklist.md 編集後の docs:generate 忘れによる drift だった。
#     既存の check_docs_generate は guard/allowlist/registry の path しか
#     見ていないため、HANDOFF.md / checklist.md / references/01-principles/*.md /
#     CLAUDE.md など generated section を含む doc 編集による KPI drift を
#     捕捉できなかった
# 理由: docs:check は KPI drift / generated section drift / hard gate を一括検証する
#       canonical truth。CI fast-gate (docs-health) で必ず実行される。pre-push で
#       同じ check を回せば「pre-push 通過 = CI docs:check 通過」を構造的に保証できる
#       （path heuristic の漏れに左右されない）
# 不可侵原則: pre-push の docs:check 通過は CI docs-health 通過を意味する
# severity: error
# コスト: ~2-3 秒 (live recalculation + semantic diff)
check_docs_drift() {
  echo "  pre-push: docs:check 実行中 (KPI drift / generated section / hard gate)..."
  DOCS_CHECK_OUTPUT=$(cd app && npm run docs:check 2>&1)
  DOCS_CHECK_EXIT=$?
  if [ "$DOCS_CHECK_EXIT" = "0" ]; then
    return 0
  fi
  # FAIL 詳細を抽出 (✗ / FAIL / drift / Hard gate fail のいずれか含む行)
  DRIFT_DETAILS=$(echo "$DOCS_CHECK_OUTPUT" \
    | grep -E "✗|FAIL|drift|Hard gate fail" \
    | head -10)
  add_error \
    "docs:check 失敗 (CI fast-gate docs-health で同じ失敗が再現する):" \
    "  修正方法:" \
    "    cd app && npm run docs:generate     # 全 generated artifact を再生成" \
    "    git add CLAUDE.md references/      # 再生成された差分を staging" \
    "    git commit -m 'chore: docs:generate ...'  # 新規 commit を積んで再 push" \
    "  失敗詳細:"
  if [ -n "$DRIFT_DETAILS" ]; then
    OLD_IFS="$IFS"
    IFS='
'
    for line in $DRIFT_DETAILS; do
      add_error "    $line"
    done
    IFS="$OLD_IFS"
  fi
}

# Check: tsc 型チェック (project references を辿る `tsc -b`)
# 学習ソース:
#   - 2026-04 AAG 5.1 release 直後、CI で TS6133 (project-checklist-collector の
#     未使用宣言) が検出された。noUnusedLocals / noUnusedParameters 違反を
#     local で完結させる仕組みが欠けていた
#   - 2026-04-13 PR #1024: pre-push の `tsc -p tsconfig.app.json --noEmit` は
#     通過したのに CI の `tsc -b && vite build` で fail (TS2786 / TS2578 の
#     test ファイル型エラー)。pre-push と CI の divergence が発生した
# 理由: strict 型エラー (noUnusedLocals / noUnusedParameters 等) を local で検出。
#       `tsc -b` は project references を辿るため CI の `tsc -b && vite build`
#       と同じ範囲をカバーする。`vite build` 自体は OOM するため省略する。
# 不可侵原則: 「pre-push を通過したら CI の tsc 部分も通過する」を維持する。
# severity: error
check_tsc() {
  echo "  pre-push: tsc -b --noEmit 実行中..."
  # tsc -b --noEmit: tsconfig.json の references 経由で tsconfig.app.json と
  # tsconfig.node.json の両方をチェック (vite.config.ts / vitest.config.ts も含む)
  TSC_OUTPUT=$(cd app && NODE_OPTIONS="--max-old-space-size=4096" npx tsc -b --noEmit 2>&1 || true)
  if echo "$TSC_OUTPUT" | grep -qE "error TS[0-9]+"; then
    TSC_SUMMARY=$(echo "$TSC_OUTPUT" | grep -E "error TS[0-9]+" | head -1)
    add_error \
      "tsc 型チェック失敗: ${TSC_SUMMARY}" \
      "  修正方法:" \
      "    cd app && npx tsc -b --noEmit   # 詳細確認 (project references を辿る)" \
      "  理由: noUnusedLocals / noUnusedParameters など strict 型エラーを" \
      "        local で完結 (CI の \`tsc -b && vite build\` 相当)。" \
      "        PR #1024 で pre-push を通過したのに CI で fail した教訓から" \
      "        pre-push でも project references を辿るように変更済"
  fi
}

# Check: lint (ESLint)
# 学習ソース: CI fast-gate step 1
# 理由: lint エラーは CI で必ず落ちる。ローカルで気づく機会を作る
# severity: error
check_lint() {
  echo "  pre-push: lint 実行中..."
  LINT_OUTPUT=$(cd app && npm run lint 2>&1 || true)
  if echo "$LINT_OUTPUT" | grep -qE "[1-9][0-9]* error"; then
    LINT_SUMMARY=$(echo "$LINT_OUTPUT" | grep "problems" | head -1)
    add_error \
      "lint エラーが残っている: ${LINT_SUMMARY}" \
      "  修正方法:" \
      "    cd app && npm run lint       # 詳細を表示" \
      "    cd app && npx eslint --fix . # 自動修正可能なものを修正"
  fi
}

# Check: format:check (Prettier)
# 学習ソース:
#   - 2026-04-13 CI で shiire-arari#0de794e が format:check に引っかかった。
#     pre-commit / pre-push に format:check が存在しなかったのが原因
#   - 2026-04-13 PR #1015 commit 297011d で testSignalIntegrityGuard.test.ts
#     (新規追加ファイル) が format:check に引っかかった。pre-push hook が
#     `.git/hooks/` に install されていなかったため warn 出力すら出なかった。
#     対策として check_format_added_files (新規追加ファイルのみ error) を併設し、
#     warn (一括修正可能) と error (新規ファイルは即時修正) の二段構えに
# 理由: CI fast-gate の format:check で落ちる前に検出するため。
#       ただし severity=warn — 複数コミットぶんを一括整形できるように push は止めない
# severity: warn (止めない)
check_format() {
  echo "  pre-push: format:check 実行中..."
  FORMAT_OUTPUT=$(cd app && npm run format:check 2>&1 || true)
  echo "$FORMAT_OUTPUT" | grep -q "Code style issues found" || return 0

  # 違反ファイル一覧を抽出 ([warn] で始まり、summary 行以外)
  BAD_FILES=$(echo "$FORMAT_OUTPUT" \
    | grep "^\[warn\]" \
    | grep -v "Code style issues found" \
    | sed 's/^\[warn\] *//')
  FILE_COUNT=$(echo "$BAD_FILES" | grep -c "^" 2>/dev/null || echo 0)

  add_warn \
    "format:check 違反: ${FILE_COUNT} ファイルが Prettier 未整形 (push は続行)" \
    "  修正方法:" \
    "    cd app && npm run format      # 全ファイルを自動整形 (推奨)" \
    "    または個別: cd app && npx prettier --write <file>"

  # 対象ファイル一覧を WARNINGS に含める (最大 20 件)
  BAD_LIST=$(echo "$BAD_FILES" | head -20)
  if [ -n "$BAD_LIST" ]; then
    add_warn "  対象ファイル (最大 20 件):"
    OLD_IFS="$IFS"
    IFS='
'
    for f in $BAD_LIST; do
      add_warn "    $f"
    done
    IFS="$OLD_IFS"
  fi
}

# Check: test:guards
# 学習ソース: CI fast-gate step 4
# 理由: 構造制約ガードは CI で落ちる。ローカルで気づく機会を作る
# severity: error
#
# 検出 strategy (2026-05-01 audit fix、Phase A3 [Trigger 層]):
#   - 旧実装は `grep -q "Test Files.*passed"` で判定していたが、失敗時の出力
#     `Test Files  1 failed | 135 passed` も "passed" を含むため greedy match
#     で常に true となり、**全 guard 失敗を検出できない構造的 bug** を持っていた
#     (= CHART-004 incident で CI まで違反が透過した root cause)
#   - exit code 経由で判定する方式に修正 (`|| true` を分解して $? を捕捉)
#   - 補助的に "Test Files <N> failed" の明示 pattern も併用
check_test_guards() {
  echo "  pre-push: test:guards 実行中..."
  GUARD_OUTPUT=$(cd app && npm run test:guards 2>&1) && GUARD_EXIT=0 || GUARD_EXIT=$?
  if [ "$GUARD_EXIT" -ne 0 ] || echo "$GUARD_OUTPUT" | grep -qE "Test Files +[0-9]+ failed"; then
    GUARD_SUMMARY=$(echo "$GUARD_OUTPUT" | grep "Tests " | head -1)
    add_error \
      "test:guards が失敗: ${GUARD_SUMMARY}" \
      "  修正方法:" \
      "    cd app && npm run test:guards   # 失敗 test を確認" \
      "  詳細: references/03-guides/guard-test-map.md"
  fi
}

# Check: 新規追加ファイルの Prettier format:check (error 級)
# 学習ソース: 2026-04-13 PR #1015 commit 297011d で testSignalIntegrityGuard.test.ts
#             (新規追加ファイル) が format:check に引っかかった。check_format は
#             warn 設計 (一括修正可能性のため) なので、新規追加 .ts(x) の
#             prettier 違反は即時 error で止める形を併設する
# 理由: 新規追加された .ts(x) ファイルは「最初の commit で format された状態」で
#       あるべき。既存ファイルの軽微な整形 drift は warn (一括修正) で十分だが、
#       新規ファイルが unformatted のまま push されると CI fast-gate で必ず
#       fail する → 新規ファイルだけ厳格に
# severity: error (止める)
check_format_added_files() {
  # 新規追加された .ts / .tsx / .css ファイルのみ対象 (test ファイルも含む)
  added_matches '^app/.+\.(ts|tsx|css)$' || return 0

  NEW_SRC=$(echo "$ADDED_FILES" \
    | grep -E '^app/.+\.(ts|tsx|css)$' \
    || true)
  [ -z "$NEW_SRC" ] && return 0

  echo "  pre-push: 新規追加ファイルの format:check 実行中..."

  # app/ からの相対パスに変換して prettier に渡す
  REL_LIST=""
  OLD_IFS="$IFS"
  IFS='
'
  for f in $NEW_SRC; do
    REL=$(echo "$f" | sed 's|^app/||')
    REL_LIST="${REL_LIST} ${REL}"
  done
  IFS="$OLD_IFS"

  # cd app && npx prettier --check で対象ファイルだけ検査
  # shellcheck disable=SC2086
  FORMAT_OUTPUT=$(cd app && npx prettier --check $REL_LIST 2>&1 || true)

  if echo "$FORMAT_OUTPUT" | grep -q "Code style issues found"; then
    BAD_FILES=$(echo "$FORMAT_OUTPUT" \
      | grep '^\[warn\]' \
      | grep -v "Code style issues found" \
      | sed 's/^\[warn\] *//')

    add_error \
      "新規追加ファイルが Prettier 未整形 (CI で必ず fail します)" \
      "  修正方法:" \
      "    cd app && npm run format" \
      "  または個別:"
    OLD_IFS="$IFS"
    IFS='
'
    for f in $BAD_FILES; do
      add_error "    cd app && npx prettier --write $f"
    done
    IFS="$OLD_IFS"
    add_error \
      "  理由: 新規追加ファイルは「最初の commit で format された状態」を必須とする。" \
      "        既存ファイルの軽微な drift は check_format (warn) で一括修正できるが、" \
      "        新規ファイルが unformatted のまま push されると CI fast-gate format:check で" \
      "        必ず fail するため、ここで error として止める"
  fi
}

# Check: 新規テストファイル → Signal Integrity advisory
# 学習ソース: projects/test-signal-integrity Phase 5 / 2026-04-13
# 理由: 新規 test ファイルは品質シグナル保全の self-check 動線が必要。
#       coverage を上げるためだけの無価値テストが混入すると H1 (False Green)
#       と H2 (Review Misleading) を生む。ただし機械的に hard gate 化できない
#       ため、作成者本人の自己点検を促す advisory として warning を返す。
# severity: warn (止めない)
# 上位原則: references/01-principles/test-signal-integrity.md
# 運用: references/03-guides/test-signal-integrity-advisory.md
check_test_signal_advisory() {
  # 新規追加ファイルのみ対象 (既存ファイル modification は対象外)
  # glob: app/src/**/*.test.ts(x), *.spec.ts(x), __tests__/**, app/e2e/**/*.spec.ts
  added_matches '^app/src/.+\.(test|spec)\.(ts|tsx)$|^app/src/.+/__tests__/.+\.(ts|tsx)$|^app/e2e/.+\.spec\.ts$' || return 0

  NEW_TESTS=$(echo "$ADDED_FILES" \
    | grep -E '^app/src/.+\.(test|spec)\.(ts|tsx)$|^app/src/.+/__tests__/.+\.(ts|tsx)$|^app/e2e/.+\.spec\.ts$' \
    || true)
  [ -z "$NEW_TESTS" ] && return 0

  COUNT=$(echo "$NEW_TESTS" | grep -c "^" 2>/dev/null || echo 0)

  add_warn \
    "[TSIG-ADVISORY] 新規テストファイル ${COUNT} 件を検出 — Signal Integrity の self-check を推奨" \
    "  なぜ: coverage を上げるためだけの無価値テストが混入すると H1 (False Green)" \
    "        / H2 (Review Misleading) を生む。機械的 hard gate にできないため自己点検で防ぐ" \
    "  Self-check (作成者が自分で確認):" \
    "    - existence-only assertion (toBeDefined() のみ) で終わっていないか" \
    "    - render / import 成功だけで満足していないか" \
    "    - snapshot だけで主要挙動を済ませていないか" \
    "    - 出力・契約・副作用・分岐のいずれかを検証しているか" \
    "    - suppress (eslint-disable / @ts-ignore) に依存していないか" \
    "    - mock call count だけで満足し、本来の観測対象を mock で置き換えていないか" \
    "  Protected harm: H1 False Green / H2 Review Misleading" \
    "  詳細: references/01-principles/test-signal-integrity.md" \
    "  運用: references/03-guides/test-signal-integrity-advisory.md" \
    "  対象ファイル (最大 20 件):"

  HEAD_LIST=$(echo "$NEW_TESTS" | head -20)
  OLD_IFS="$IFS"
  IFS='
'
  for f in $HEAD_LIST; do
    add_warn "    $f"
  done
  IFS="$OLD_IFS"

  add_warn "  (このアドバイザリは push を止めません)"
}

# ──────────────────────────────────────────────────────────────────────
# CHECK_REGISTRY
# ──────────────────────────────────────────────────────────────────────
# 新しい check を追加するときは (1) 上に関数を定義し (2) ここに名前を追加する。
# 実行順: 速いもの → 遅いもの (失敗時のフィードバックを速くするため)
CHECK_REGISTRY="
  check_doc_registry
  check_principles_json
  check_project_metadata
  check_docs_generate
  check_docs_drift
  check_tsc
  check_lint
  check_format
  check_format_added_files
  check_test_guards
  check_test_signal_advisory
"

for check in $CHECK_REGISTRY; do
  if should_skip "$check"; then
    echo "  pre-push: $check skipped (= skip-rules.json で除外)"
    continue
  fi
  $check
done

# ──────────────────────────────────────────────────────────────────────
# 結果出力 (AAG Response 統一フォーマット)
# ──────────────────────────────────────────────────────────────────────

if [ -n "$ERRORS" ]; then
  echo ""
  npx tsx tools/aag-render-cli.ts \
    now governance-ops \
    "pre-push: 修正漏れを検出" \
    "push 前チェックでエラーが見つかった" \
    "以下を修正してから再度 push してください" \
    2>/dev/null || {
    echo "⚡ 今すぐ修正 [governance-ops]"
    echo "  pre-push: 修正漏れを検出"
    echo "  理由: push 前チェックでエラーが見つかった"
  }
  echo ""
  echo "  エラー (push を止める):"
  printf "    %b" "$ERRORS"
  if [ -n "$WARNINGS" ]; then
    echo ""
    echo "  警告 (push は続行していた):"
    printf "    %b" "$WARNINGS"
  fi
  echo ""
  exit 1
fi

if [ -n "$WARNINGS" ]; then
  echo ""
  echo "⚠ pre-push 警告 (push は続行):"
  printf "    %b" "$WARNINGS"
  echo ""
fi

echo "  pre-push: OK"
exit 0
